generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CompanyStatus {
  ACTIVE
  DISABLED
}

enum MembershipStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum Role {
  OWNER
  ADMIN
  USER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum Permission {
  BOOKING_VIEW
  BOOKING_CREATE
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAIL
  LOGOUT
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_SUCCESS
  SESSION_REVOKED
  INVITE_SENT
  INVITE_ACCEPTED
  INVITE_REVOKED
  MEMBERSHIP_DISABLED
  MEMBERSHIP_ENABLED
  MEMBERSHIP_ROLE_CHANGED
  USER_DISABLED
  TENANT_SELECTED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String?    @unique
  phoneNumber  String?
  description  String?
  passwordHash String
  status       UserStatus @default(ACTIVE)

  memberships Membership[]
  sessions    Session[]
  resetTokens PasswordResetToken[]
  authEvents  AuthEvent[]
  invitesSent Invite[]             @relation("InviteCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Company {
  id     String        @id @default(cuid())
  name   String
  slug   String?       @unique
  status CompanyStatus @default(ACTIVE)

  memberships    Membership[]
  invites        Invite[]
  authEvents     AuthEvent[]
  activeSessions Session[]    @relation("SessionActiveCompany")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Membership {
  id        String           @id @default(cuid())
  userId    String
  companyId String
  role      Role
  status    MembershipStatus @default(ACTIVE)

  permissions MembershipPermission[]

  priceListId String?
  priceList   PriceList? @relation(fields: [priceListId], references: [id], onDelete: SetNull)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId, status])
  @@index([userId, status])
}

model MembershipPermission {
  id           String     @id @default(cuid())
  membershipId String
  permission   Permission

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([membershipId, permission])
  @@index([permission])
}

model Invite {
  id        String       @id @default(cuid())
  companyId String
  email     String
  role      Role         @default(USER)
  status    InviteStatus @default(PENDING)

  username    String?
  phoneNumber String?
  description String?
  priceListId String?

  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  createdByUserId String?
  createdByUser   User?   @relation("InviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  priceList PriceList? @relation(fields: [priceListId], references: [id], onDelete: SetNull)

  permissions InvitePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([email, status])
  @@index([priceListId])
}

model InvitePermission {
  id         String     @id @default(cuid())
  inviteId   String
  permission Permission

  invite Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([inviteId, permission])
  @@index([permission])
}

model Session {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  activeCompanyId String?

  ipHash        String?
  userAgentHash String?

  lastSeenAt DateTime?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCompany Company? @relation("SessionActiveCompany", fields: [activeCompanyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
  @@index([activeCompanyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
}

model AuthEvent {
  id   String        @id @default(cuid())
  type AuthEventType

  userId    String?
  companyId String?

  // Keep for failed login attempts where userId is unknown
  email String?

  ipHash        String?
  userAgentHash String?

  // Small metadata; never store secrets
  meta Json?

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([companyId, createdAt])
}

model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

enum PricingMode {
  FIXED
  REQUEST
}

enum RequestStatus {
  NEW
  CONFIRMED
  REJECTED
  CANCELLED
}

model Category {
  id        String  @id @default(cuid())
  name      String  @unique
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Service {
  id          String      @id @default(cuid())
  title       String
  description String
  pricingMode PricingMode @default(FIXED)
  priceCents  Int?
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestItems RequestItem[]

  @@index([categoryId])
  @@index([isActive, sortOrder])
}

model Request {
  id     String        @id @default(cuid())
  status RequestStatus @default(NEW)

  customerName  String
  customerEmail String
  customerPhone String?

  message String?

  preferredFrom DateTime?
  preferredTo   DateTime?

  items RequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model RequestItem {
  id String @id @default(cuid())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  titleSnapshot String
  quantity      Int     @default(1)
  notes         String?

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([serviceId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  options ProductOption[]
}

model ProductOption {
  id          String   @id @default(cuid())
  productId   String
  code        String
  label       String
  description String?
  category    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceListItems PriceListItem[]

  @@unique([productId, code])
  @@index([productId, isActive, sortOrder])
}

model PriceListItem {
  id                      String    @id @default(cuid())
  priceListId             String
  productOptionId         String
  customerPriceCents      Int
  subcontractorPriceCents Int
  discountAmountCents     Int?
  discountEndsAt          DateTime?
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  priceList     PriceList     @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productOption ProductOption @relation(fields: [productOptionId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productOptionId])
  @@index([priceListId, isActive])
  @@index([productOptionId, isActive])
}

model PriceList {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique
  description String?
  isActive    Boolean @default(true)

  items          PriceListItem[]
  specialOptions PriceListSpecialOption[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  invites     Invite[]
}

enum SpecialOptionType {
  RETURN
  XTRA
}

model PriceListSpecialOption {
  id          String    @id @default(cuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  type               SpecialOptionType
  code               String
  label              String?
  description        String?
  customerPrice      Decimal           @db.Decimal(10, 2)
  subcontractorPrice Decimal           @db.Decimal(10, 2)
  discountAmount     String?
  discountEndsAt     DateTime?
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([priceListId, type, code])
  @@index([priceListId, type])
}
