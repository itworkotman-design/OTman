generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  passwordHash          String
  status                UserStatus           @default(ACTIVE)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  description           String?
  phoneNumber           String?
  username              String?              @unique
  address               String?
  logoPath              String?
  usernameDisplayColor  String?
  languagePreference    String?
  legacyWordpressUserId Int?                 @unique
  authEvents            AuthEvent[]
  invitesSent           Invite[]             @relation("InviteCreatedBy")
  memberships           Membership[]
  resetTokens           PasswordResetToken[]
  sessions              Session[]
  blogPosts             BlogPost[]

  @@index([status])
}

model Company {
  id                      String                   @id @default(cuid())
  name                    String
  slug                    String?                  @unique
  status                  CompanyStatus            @default(ACTIVE)
  orderEmailsEnabled      Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  authEvents              AuthEvent[]
  invites                 Invite[]
  memberships             Membership[]
  orders                  Order[]
  activeSessions          Session[]                @relation("SessionActiveCompany")
  recurringOrderTemplates RecurringOrderTemplate[]

  @@index([status])
}

model Membership {
  id                             String                   @id @default(cuid())
  userId                         String
  companyId                      String
  role                           Role
  status                         MembershipStatus         @default(ACTIVE)
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt
  warehouseEmail                 String?
  legacyWordpressUserId          Int?                     @unique
  company                        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions                    MembershipPermission[]
  membershipPriceLists           MembershipPriceList[]
  createdOrders                  Order[]                  @relation("OrderCreatedByMembership")
  orders                         Order[]
  ordersLastEdited               Order[]                  @relation("OrderLastEditedByMembership")
  sentOrderEmails                OrderEmailMessage[]      @relation("OrderEmailSentByMembership")
  orderEvents                    OrderEvent[]
  resolvedOrderNotifications     OrderNotification[]      @relation("OrderNotificationResolvedByMembership")
  createdRecurringOrderTemplates RecurringOrderTemplate[] @relation("RecurringOrderTemplateCreatedByMembership")

  @@unique([userId, companyId])
  @@index([companyId, status])
  @@index([userId, status])
}

model MembershipPriceList {
  id           String     @id @default(cuid())
  membershipId String
  priceListId  String
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  priceList    PriceList  @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([membershipId, priceListId])
  @@index([membershipId])
  @@index([priceListId])
}

model MembershipPermission {
  id           String     @id @default(cuid())
  membershipId String
  permission   Permission
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, permission])
  @@index([permission])
}

model Invite {
  id                   String             @id @default(cuid())
  companyId            String
  email                String
  role                 Role               @default(USER)
  status               InviteStatus       @default(PENDING)
  tokenHash            String             @unique
  expiresAt            DateTime
  acceptedAt           DateTime?
  revokedAt            DateTime?
  createdByUserId      String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  description          String?
  phoneNumber          String?
  priceListId          String?
  warehouseEmail       String?
  username             String?
  address              String?
  logoPath             String?
  usernameDisplayColor String?
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser        User?              @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])
  priceList            PriceList?         @relation(fields: [priceListId], references: [id])
  permissions          InvitePermission[]

  @@index([companyId, status])
  @@index([email, status])
  @@index([priceListId])
}

model InvitePermission {
  id         String     @id @default(cuid())
  inviteId   String
  permission Permission
  createdAt  DateTime   @default(now())
  invite     Invite     @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@unique([inviteId, permission])
  @@index([permission])
}

model Session {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  ipHash          String?
  userAgentHash   String?
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  activeCompanyId String?
  activeCompany   Company?  @relation("SessionActiveCompany", fields: [activeCompanyId], references: [id])
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([activeCompanyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthEvent {
  id            String        @id @default(cuid())
  type          AuthEventType
  userId        String?
  companyId     String?
  email         String?
  ipHash        String?
  userAgentHash String?
  meta          Json?
  createdAt     DateTime      @default(now())
  company       Company?      @relation(fields: [companyId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([companyId, createdAt])
}

model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  services  Service[]

  @@index([isActive, sortOrder])
}

model Service {
  id           String        @id @default(cuid())
  title        String
  description  String
  pricingMode  PricingMode   @default(FIXED)
  priceCents   Int?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  categoryId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  requestItems RequestItem[]
  category     Category      @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([isActive, sortOrder])
}

model Request {
  id            String        @id @default(cuid())
  status        RequestStatus @default(NEW)
  customerName  String
  customerEmail String
  customerPhone String?
  message       String?
  preferredFrom DateTime?
  preferredTo   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         RequestItem[]

  @@index([status, createdAt])
}

model RequestItem {
  id            String   @id @default(cuid())
  requestId     String
  serviceId     String?
  titleSnapshot String
  quantity      Int      @default(1)
  notes         String?
  createdAt     DateTime @default(now())
  request       Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  service       Service? @relation(fields: [serviceId], references: [id])

  @@index([requestId])
  @@index([serviceId])
}

model Product {
  id                  String          @id @default(cuid())
  name                String
  code                String          @unique
  description         String?
  sortOrder           Int             @default(0)
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  allowDeliveryTypes  Boolean         @default(true)
  allowDemont         Boolean         @default(true)
  allowExtraServices  Boolean         @default(true)
  allowHoursInput     Boolean         @default(false)
  allowInstallOptions Boolean         @default(true)
  allowPeopleCount    Boolean         @default(false)
  allowQuantity       Boolean         @default(true)
  allowReturnOptions  Boolean         @default(true)
  autoXtraPerPallet   Boolean         @default(false)
  productType         ProductType     @default(PHYSICAL)
  autoDeliveryPrice   Json?
  customSections      Json?
  deliveryTypes       Json?
  allowModelNumber    Boolean         @default(true)
  options             ProductOption[]
}

model ProductOption {
  id             String          @id @default(cuid())
  productId      String
  code           String
  label          String
  description    String?
  category       String?
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  priceListItems PriceListItem[]
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, code])
  @@index([productId, isActive, sortOrder])
}

model PriceListItem {
  id                      String        @id @default(cuid())
  priceListId             String
  customerPriceCents      Int
  subcontractorPriceCents Int
  isActive                Boolean       @default(true)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  productOptionId         String
  discountAmountCents     Int?
  discountEndsAt          DateTime?
  priceList               PriceList     @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productOption           ProductOption @relation(fields: [productOptionId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productOptionId])
  @@index([priceListId, isActive])
  @@index([productOptionId, isActive])
}

model PriceList {
  id                   String                   @id @default(cuid())
  name                 String
  code                 String                   @unique
  description          String?
  isActive             Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  invites              Invite[]
  membershipPriceLists MembershipPriceList[]
  items                PriceListItem[]
  specialOptions       PriceListSpecialOption[]
}

model PriceListSpecialOption {
  id                 String            @id @default(cuid())
  priceListId        String
  type               SpecialOptionType
  code               String
  label              String?
  description        String?
  customerPrice      Decimal           @db.Decimal(10, 2)
  subcontractorPrice Decimal           @db.Decimal(10, 2)
  discountAmount     String?
  discountEndsAt     DateTime?
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  attachments        OrderAttachment[]
  priceList          PriceList         @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([priceListId, type, code])
  @@index([priceListId, type])
}

model Order {
  id                                 String                    @id @default(cuid())
  createdAt                          DateTime                  @default(now())
  updatedAt                          DateTime                  @updatedAt
  companyId                          String
  createdByMembershipId              String
  description                        String?
  modelNr                            String?
  deliveryDate                       String?
  timeWindow                         String?
  pickupAddress                      String?
  deliveryAddress                    String?
  returnAddress                      String?
  drivingDistance                    String?
  customerName                       String?
  phone                              String?
  phoneTwo                           String?
  email                              String?
  customerComments                   String?
  floorNo                            String?
  lift                               String?
  cashierName                        String?
  cashierPhone                       String?
  subcontractor                      String?
  driver                             String?
  secondDriver                       String?
  driverInfo                         String?
  licensePlate                       String?
  deviation                          String?
  feeExtraWork                       Boolean                   @default(false)
  extraWorkMinutes                   Int                       @default(0)
  feeAddToOrder                      Boolean                   @default(false)
  statusNotes                        String?
  status                             String?
  dontSendEmail                      Boolean                   @default(false)
  priceExVat                         Int                       @default(0)
  priceSubcontractor                 Int                       @default(0)
  rabatt                             String?
  dnbDiscount                        Boolean                   @default(false)
  leggTil                            String?
  subcontractorMinus                 String?
  subcontractorPlus                  String?
  productsSummary                    String?
  deliveryTypeSummary                String?
  servicesSummary                    String?
  productCardsSnapshot               Json?
  pricingSnapshot                    Json?
  extraPickupAddress                 String[]
  customerMembershipId               String?
  subcontractorMembershipId          String?
  customerLabel                      String?
  priceListId                        String?
  orderNumber                        String?
  displayId                          Int
  lastEditedByMembershipId           String?
  gsmExternalId                      String?
  gsmLastSyncedAt                    DateTime?
  gsmLastTaskState                   String?
  gsmLastWebhookAt                   DateTime?
  gsmOrderId                         String?
  gsmSentAt                          DateTime?
  gsmSyncStatus                      String?
  emailThreadToken                   String?                   @unique
  lastInboundEmailAt                 DateTime?
  lastOutboundEmailAt                DateTime?
  orderCreatorEmailReadAt            DateTime?
  needsEmailAttention                Boolean                   @default(false)
  unreadInboundEmailCount            Int                       @default(0)
  expressDelivery                    Boolean                   @default(false)
  extraPickupContacts                Json?
  contactCustomerForCustomTimeWindow Boolean                   @default(false)
  customTimeContactNote              String?
  lastNotificationAt                 DateTime?
  needsNotificationAttention         Boolean                   @default(false)
  unreadNotificationCount            Int                       @default(0)
  recurringOrderTemplateId           String?
  recurringOrderOccurrenceDate       String?
  gsmWebhookEvents                   GsmWebhookEvent[]
  company                            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByMembership                Membership                @relation("OrderCreatedByMembership", fields: [createdByMembershipId], references: [id])
  customerMembership                 Membership?               @relation(fields: [customerMembershipId], references: [id])
  lastEditedByMembership             Membership?               @relation("OrderLastEditedByMembership", fields: [lastEditedByMembershipId], references: [id])
  orderAttachments                   OrderAttachment[]
  emailMessages                      OrderEmailMessage[]
  events                             OrderEvent[]
  gsmTasks                           OrderGsmTask[]
  items                              OrderItem[]
  notifications                      OrderNotification[]
  recurringOrderOccurrence           RecurringOrderOccurrence?
  legacyWordpressOrderId             Int?                      @unique
  legacyWordpressAuthorId            Int?
  legacyWordpressRawMeta             Json?

  completedAt    DateTime?
  gdprAnonymized Boolean   @default(false)
  gdprDeletedAt  DateTime?
  paidAt         DateTime?
  invoicedAt     DateTime?
  gdprHold       Boolean   @default(false)
  gdprHoldReason String?
  gdprHoldSetAt  DateTime?

  @@unique([companyId, displayId])
  @@unique([recurringOrderTemplateId, recurringOrderOccurrenceDate])
  @@index([companyId, createdAt])
  @@index([status])
  @@index([deliveryDate])
  @@index([customerMembershipId])
  @@index([subcontractorMembershipId])
  @@index([gsmOrderId])
  @@index([gsmExternalId])
  @@index([gsmSyncStatus])
  @@index([needsEmailAttention, lastInboundEmailAt])
  @@index([needsNotificationAttention, lastNotificationAt])
  @@index([recurringOrderTemplateId])
  @@index([status, paidAt, gdprHold, gdprAnonymized])
  @@index([status, invoicedAt])
}

model OrderEvent {
  id                String         @id @default(cuid())
  orderId           String
  companyId         String
  type              OrderEventType
  actorMembershipId String?
  actorName         String?
  actorEmail        String?
  actorSource       String?
  payload           Json
  createdAt         DateTime       @default(now())
  actorMembership   Membership?    @relation(fields: [actorMembershipId], references: [id])
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([companyId, createdAt])
  @@index([type, createdAt])
  @@index([actorMembershipId, createdAt])
}

model OrderEmailMessage {
  id                 String              @id @default(cuid())
  orderId            String
  companyId          String
  direction          OrderEmailDirection
  status             OrderEmailStatus
  sentByMembershipId String?
  externalMessageId  String?
  subject            String
  bodyText           String?
  bodyHtml           String?
  fromEmail          String
  fromName           String?
  toEmail            String
  toName             String?
  createdAt          DateTime            @default(now())
  sentAt             DateTime?
  receivedAt         DateTime?
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sentByMembership   Membership?         @relation("OrderEmailSentByMembership", fields: [sentByMembershipId], references: [id])
  source             OrderEmailSource    @default(APP)
  gmailMessageId     String?
  gmailThreadId      String?

  @@index([orderId, createdAt])
  @@index([companyId, createdAt])
  @@index([direction, createdAt])
  @@index([status, createdAt])
  @@index([sentByMembershipId, createdAt])
  @@index([externalMessageId])
}

model OrderNotification {
  id                     String                @id @default(cuid())
  orderId                String
  companyId              String
  type                   OrderNotificationType
  title                  String
  message                String
  payload                Json?
  scheduledFor           DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  resolvedAt             DateTime?
  resolvedByMembershipId String?
  order                  Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  resolvedByMembership   Membership?           @relation("OrderNotificationResolvedByMembership", fields: [resolvedByMembershipId], references: [id])

  @@index([orderId, createdAt])
  @@index([companyId, resolvedAt, createdAt])
  @@index([resolvedByMembershipId, createdAt])
}

model OrderItem {
  id                      String   @id @default(cuid())
  createdAt               DateTime @default(now())
  orderId                 String
  cardId                  Int
  productId               String?
  productCode             String?
  productName             String?
  deliveryType            String?
  itemType                String
  optionId                String?
  optionCode              String?
  optionLabel             String?
  quantity                Float    @default(1)
  customerPriceCents      Int?
  subcontractorPriceCents Int?
  rawData                 Json?
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@index([optionId])
}

model OrderGsmTask {
  id            String    @id @default(cuid())
  orderId       String
  gsmTaskId     String    @unique
  gsmOrderId    String?
  category      String?
  reference     String?
  state         String?
  address       String?
  completedAt   DateTime?
  lastWebhookAt DateTime?
  lastSyncedAt  DateTime?
  rawPayload    Json?
  hasNotes      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([gsmOrderId])
  @@index([state])
}

model GsmWebhookEvent {
  id              String    @id @default(cuid())
  gsmRequestId    String?
  gsmTaskId       String?
  gsmOrderId      String?
  topic           String?
  eventType       String?
  orderId         String?
  processed       Boolean   @default(false)
  processingError String?
  payload         Json
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  order           Order?    @relation(fields: [orderId], references: [id])

  @@index([gsmRequestId])
  @@index([gsmTaskId])
  @@index([gsmOrderId])
  @@index([orderId])
  @@index([processed, receivedAt])
}

model OrderAttachment {
  id                          String                  @id @default(cuid())
  legacyWordpressAttachmentId Int?
  orderId                     String
  filename                    String
  mimeType                    String?
  sizeBytes                   Int?
  storagePath                 String
  createdAt                   DateTime                @default(now())
  priceListSpecialOptionId    String?
  gsmDocumentId               String?
  gsmTaskId                   String?
  source                      String?
  sourceUrl                   String?
  category                    AttachmentCategory      @default(ATTACHMENT)
  order                       Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  priceListSpecialOption      PriceListSpecialOption? @relation(fields: [priceListSpecialOptionId], references: [id])

  @@unique([orderId, legacyWordpressAttachmentId])
  @@index([orderId, createdAt])
}

model PendingOrderAttachment {
  id          String             @id @default(cuid())
  sessionId   String
  filename    String
  mimeType    String?
  sizeBytes   Int?
  storagePath String
  createdAt   DateTime           @default(now())
  category    AttachmentCategory @default(ATTACHMENT)

  @@index([sessionId, createdAt])
}

model CompanyOrderCounter {
  companyId  String   @id
  nextNumber Int
  updatedAt  DateTime @updatedAt
}

model RecurringOrderTemplate {
  id                    String         @id @default(cuid())
  companyId             String
  createdByMembershipId String
  name                  String
  isPaused              Boolean        @default(false)
  recurrenceType        RecurrenceType
  recurrenceConfig      Json
  leadTimeDays          Int            @default(3)
  startDate             String
  endDate               String?
  orderDefaults         Json
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  company             Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByMembership Membership                 @relation("RecurringOrderTemplateCreatedByMembership", fields: [createdByMembershipId], references: [id])
  occurrences         RecurringOrderOccurrence[]

  @@index([companyId, isPaused])
}

model RecurringOrderOccurrence {
  id             String                         @id @default(cuid())
  templateId     String
  occurrenceDate String
  status         RecurringOrderOccurrenceStatus @default(PENDING)
  orderId        String?                        @unique
  failureReason  String?
  generatedAt    DateTime?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  template RecurringOrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order    Order?                 @relation(fields: [orderId], references: [id])

  @@unique([templateId, occurrenceDate])
  @@index([templateId, status])
}

model SiteStats {
  id                String   @id @default("main")
  productsInstalled Int
  kmDriven          Int
  ordersCompleted   Int
  updatedAt         DateTime @updatedAt
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum OrderEmailSource {
  APP
  GMAIL
}

enum CompanyStatus {
  ACTIVE
  DISABLED
}

enum MembershipStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum Role {
  OWNER
  ADMIN
  USER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum Permission {
  BOOKING_VIEW
  BOOKING_CREATE
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAIL
  LOGOUT
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_SUCCESS
  SESSION_REVOKED
  INVITE_SENT
  INVITE_ACCEPTED
  INVITE_REVOKED
  MEMBERSHIP_DISABLED
  MEMBERSHIP_ENABLED
  MEMBERSHIP_ROLE_CHANGED
  USER_DISABLED
  TENANT_SELECTED
}

enum ProductType {
  PHYSICAL
  PALLET
  LABOR
}

enum PricingMode {
  FIXED
  REQUEST
}

enum RequestStatus {
  NEW
  CONFIRMED
  REJECTED
  CANCELLED
}

enum OrderEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  GDPR_ANONYMIZED
  GDPR_POD_DELETED
  GDPR_HOLD_SET
  GDPR_HOLD_REMOVED
}

enum OrderEmailDirection {
  OUTBOUND
  INBOUND
}

enum OrderEmailStatus {
  SENT
  SENT_WITH_SYNC_WARNING
  FAILED
  RECEIVED
}

enum OrderNotificationType {
  MANUAL_REVIEW
  GSM_REVIEW
  CAPACITY_REVIEW
  CUSTOM
}

enum AttachmentCategory {
  ATTACHMENT
  RECEIPT
}

enum SpecialOptionType {
  RETURN
  XTRA
  EXTRA_SERVICE
}

enum RecurrenceType {
  WEEKLY
  MONTHLY
  CUSTOM_DATES
}

enum RecurringOrderOccurrenceStatus {
  PENDING
  CREATED
  SKIPPED
  FAILED
}

model ShiftLeader {
  id        String   @id @default(cuid())
  companyId String   @unique
  userId    String
  username  String
  date      String
  setAt     DateTime @default(now())
}

model BlogPost {
  id                String         @id @default(cuid())
  slug              String         @unique
  status            BlogPostStatus @default(DRAFT)

  title             Json
  excerpt           Json
  seoTitle          Json?
  seoDescription    Json?
  noIndex           Boolean        @default(false)

  coverImagePath    String?
  coverImageAlt     Json?

  authorId          String?
  authorDisplayName String?

  isPinned          Boolean        @default(false)
  pinnedAt          DateTime?
  publishedAt       DateTime?
  archivedAt        DateTime?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  author            User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  sections          BlogSection[]
  tags              BlogPostTag[]

  @@index([status, isPinned, pinnedAt, createdAt])
  @@index([status, publishedAt])
  @@index([authorId])
}

model BlogTag {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now())

  posts     BlogPostTag[]
}

model BlogPostTag {
  blogPostId String
  blogTagId  String

  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogTag    BlogTag  @relation(fields: [blogTagId], references: [id], onDelete: Cascade)

  @@id([blogPostId, blogTagId])
  @@index([blogTagId])
}

model BlogSection {
  id         String          @id @default(cuid())
  blogPostId String
  type       BlogSectionType
  position   Int
  data       Json

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  blogPost   BlogPost        @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, position])
  @@index([blogPostId])
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlogSectionType {
  RICH_TEXT
  IMAGE
  IMAGE_TEXT
  GALLERY
  CAROUSEL
  QUOTE
  CTA
  DIVIDER
  SPACER
}
